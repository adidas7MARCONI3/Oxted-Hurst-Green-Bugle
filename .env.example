# ── Core ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── National Rail (Darwin OpenLDBWS) ──────────────────────────────────────
# Register at: https://realtime.nationalrail.co.uk/OpenLDBWSRegistration/
DARWIN_API_KEY=your-darwin-api-key

# ── Sports ────────────────────────────────────────────────────────────────
# Play-Cricket: https://play-cricket.com/api
PLAY_CRICKET_API_KEY=your-play-cricket-key
# Your club's site ID from their Play-Cricket URL
PLAY_CRICKET_SITE_ID=12345

# FA Full-Time: club name as it appears on fulltime.thefa.com
FA_CLUB_NAME=Oxted & District FC
FA_COMPETITION_ID=

# England Hockey club name and GMS ID
HOCKEY_CLUB_NAME=Oxted HC
HOCKEY_CLUB_ID=

# ── Bins ──────────────────────────────────────────────────────────────────
# Find your UPRN at: https://www.tandridge.gov.uk/rubbish-and-recycling/when-is-my-collection-day
BINS_UPRN=your-uprn

# ── Alerts: Twilio SMS ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+441234567890
TWILIO_TO=+447700123456

# ── Alerts: Resend email ──────────────────────────────────────────────────
# Sign up at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
ALERT_EMAIL_FROM=bugle@yourdomain.com
ALERT_EMAIL_TO=you@yourdomain.com
