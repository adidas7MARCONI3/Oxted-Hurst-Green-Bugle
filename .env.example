# ── Core ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── National Rail (Darwin OpenLDBWS) ──────────────────────────────────────
# Register at: https://realtime.nationalrail.co.uk/OpenLDBWSRegistration/
DARWIN_API_KEY=your-darwin-api-key

# ── Sports ────────────────────────────────────────────────────────────────
# Play-Cricket: https://play-cricket.com/api
PLAY_CRICKET_API_KEY=your-play-cricket-key
# Your club's site ID from their Play-Cricket URL
PLAY_CRICKET_SITE_ID=12345

# FA Full-Time: club name as it appears on fulltime.thefa.com
FA_CLUB_NAME=Oxted & District FC
FA_COMPETITION_ID=

# England Hockey club name and GMS ID
HOCKEY_CLUB_NAME=Oxted HC
HOCKEY_CLUB_ID=

# ── Roads (DfT Street Manager Open Data) ──────────────────────────────────
# The roads collector uses the free, KEYLESS Street Manager Open Data feed —
# no API key needed. Optionally override the feed URL to pin a dated archive:
# https://department-for-transport-streetmanager.github.io/street-manager-docs/open-data/
# STREET_MANAGER_OPEN_DATA_URL=https://opendata.streetmanager.service.gov.uk/permit/latest.json

# ── Street Manager closure service (streetworks/) ─────────────────────────
# Push feed over AWS SNS — see streetworks/README.md. The two you care about:
SURREY_SWA_CODE=0000
# Bounding box covering Oxted & Hurst Green (defaults shown):
# BBOX_MIN_LAT=51.225
# BBOX_MAX_LAT=51.275
# BBOX_MIN_LON=-0.045
# BBOX_MAX_LON=0.025
# Postgres/PostGIS DSN (omit to use the in-memory store):
# DATABASE_URL=postgresql+psycopg://user:pass@localhost/streetworks
# SNS_VERIFY_SIGNATURES=true
# HEALTH_MAX_SILENCE_HOURS=6

# ── Bins ──────────────────────────────────────────────────────────────────
# Find your UPRN at: https://www.tandridge.gov.uk/rubbish-and-recycling/when-is-my-collection-day
BINS_UPRN=your-uprn

# ── Alerts: Twilio SMS ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+441234567890
TWILIO_TO=+447700123456

# ── Alerts: Resend email ──────────────────────────────────────────────────
# Sign up at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
ALERT_EMAIL_FROM=bugle@yourdomain.com
ALERT_EMAIL_TO=you@yourdomain.com
